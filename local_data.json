{
    "model": "forum.question",
    "pk": 1,
    "fields": {
        "title": "What is the correct spelling of 'school' in Sorani Kurdish?",
        "body": "I've seen it written as مەکتەب and قوتابخانە in different sources. Which is correct or more common in modern Sorani?",
