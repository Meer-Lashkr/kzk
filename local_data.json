            "sara_k"
        ],
        "status": "active",
        "created_at": "2026-04-02T13:47:38.944Z",
        "updated_at": "2026-04-02T13:47:38.944Z",
        "tags": [
            2,
            4
        ]
    }
},
{
    "model": "forum.question",
    "pk": 2,
    "fields": {
        "title": "How do plural forms work in Sorani Kurdish?",
