{
    "model": "forum.answer",
    "pk": 1,
    "fields": {
        "question": 1,
        "body": "قوتابخانە is the more native Kurdish word and is preferred in modern Sorani usage. مەکتەب is borrowed from Arabic.",
        "author": [
            "moderator"
        ],
        "is_accepted": false,
        "created_at": "2026-04-02T13:47:38.948Z",
        "updated_at": "2026-04-02T13:47:38.948Z"
    }
},
{
    "model": "forum.answer",
    "pk": 2,
    "fields": {
        "question": 1,
        "body": "Both are used, but قوتابخانە is more commonly found in formal writing and education contexts.",
        "author": [
            "karo"
        ],
        "is_accepted": false,
        "created_at": "2026-04-02T13:47:38.948Z",
        "updated_at": "2026-04-02T13:47:38.948Z"
    }
},
{
    "model": "forum.answer",
    "pk": 3,
    "fields": {
        "question": 2,
        "body": "Sorani plural is generally formed by adding -ەکان for definite plural and -ان for indefinite. For example: کتێب (book) → کتێبەکان (the books).",
        "author": [
            "admin"
        ],
        "is_accepted": true,
        "created_at": "2026-04-02T13:47:38.949Z",
        "updated_at": "2026-04-02T13:47:38.949Z"
    }
},
{
    "model": "forum.answer",
    "pk": 4,
    "fields": {
        "question": 3,
        "body": "Key differences: Kurmanji uses Latin/Cyrillic scripts, Sorani uses Arabic script. Kurmanji has grammatical gender (masculine/feminine), Sorani does not. Verb conjugation patterns also differ significantly.",
        "author": [
            "sara_k"
        ],
        "is_accepted": false,
        "created_at": "2026-04-02T13:47:38.949Z",
        "updated_at": "2026-04-02T13:47:38.949Z"
    }
},
